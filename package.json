{
  "name": "double-camera",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "npx react-native run-android",
    "ios": "npx react-native run-ios",
    "android:local": "ENVFILE=.env.local npx react-native run-android",
    "android:develop": "ENVFILE=.env.develop npx react-native run-android",
    "android:stage": "ENVFILE=.env.stage npx react-native run-android",
    "android:production": "ENVFILE=.env.production npx react-native run-android",
    "ios:local": "ENVFILE=.env.local npx react-native run-ios",
    "ios:develop": "ENVFILE=.env.develop npx react-native run-ios",
    "ios:stage": "ENVFILE=.env.stage npx react-native run-ios",
    "ios:production": "ENVFILE=.env.production npx react-native run-ios",
    "ios:local:device": "ENVFILE=.env.local npx react-native run-ios --udid 00008020-0001116436DA002E --extra-params \"-allowProvisioningUpdates\"",
    "ios:develop:device": "ENVFILE=.env.develop npx react-native run-ios --udid 00008020-0001116436DA002E --extra-params \"-allowProvisioningUpdates\"",
    "ios:stage:device": "ENVFILE=.env.stage npx react-native run-ios --udid 00008020-0001116436DA002E --extra-params \"-allowProvisioningUpdates\"",
    "ios:production:device": "ENVFILE=.env.production npx react-native run-ios --udid 00008020-0001116436DA002E --extra-params \"-allowProvisioningUpdates\"",
    "format": "prettier --write .",
    "lint": "npx eslint .",
    "prepare": "husky install",
    "start": "npx react-native start",
    "start:reset": "npx react-native start --reset-cache",
    "test": "npx jest"
  },
